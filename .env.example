# 服务端口
PORT=4000

# 数据库
# 生产环境使用 PostgreSQL: postgres://user:pass@localhost:5432/lightglass
# 开发环境若未设置则使用 SQLite 内存数据库
DATABASE_URL=

# JWT 密钥
JWT_SECRET=please-change-me-in-production

# MinIO / S3 配置 (可选, 留空则使用本地磁盘)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=lightglass
S3_ACCESS_KEY=
S3_SECRET_KEY=

# 静态资源目录
STATIC_DIR=./public

# 前端地址 (CORS)
EDITOR_ORIGIN=http://localhost:5173
VIEWER_ORIGIN=http://localhost:5174
