{
  "name": "lightglass",
  "version": "0.1.0",
  "private": true,
  "description": "LightGlass — 现代化 Web 可视化桌面编辑系统",
  "scripts": {
    "dev": "concurrently -k -n editor,viewer,server -c cyan,magenta,yellow \"pnpm --filter @lightglass/editor dev\" \"pnpm --filter @lightglass/viewer dev\" \"pnpm --filter @lightglass/server dev\"",
    "start": "node scripts/start.mjs",
    "stop": "node scripts/stop.mjs",
    "build": "pnpm -r --filter=!@lightglass/server build && pnpm --filter @lightglass/server build",
    "build:editor": "pnpm --filter @lightglass/editor build",
    "build:viewer": "pnpm --filter @lightglass/viewer build",
    "build:server": "pnpm --filter @lightglass/server build",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "clean": "pnpm -r exec rm -rf dist .turbo node_modules"
  },
  "devDependencies": {
    "concurrently": "9.1.0",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.28.1"
}
