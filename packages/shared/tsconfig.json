{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "declaration": true,
    "baseUrl": ".",
    "paths": {
      "@lightglass/shared": ["./src/index.ts"],
      "@lightglass/shared/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
